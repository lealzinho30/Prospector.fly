{
  "version": 2,
  "builds": [
    { "src": "api/claude.js",    "use": "@vercel/node" },
    { "src": "api/apollo.js",    "use": "@vercel/node" },
    { "src": "api/socios.js",    "use": "@vercel/node" },
    { "src": "api/contacts.js",  "use": "@vercel/node" },
    { "src": "index.html",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude",    "dest": "/api/claude.js"   },
    { "src": "/api/apollo",    "dest": "/api/apollo.js"   },
    { "src": "/api/socios",    "dest": "/api/socios.js"   },
    { "src": "/api/contacts",  "dest": "/api/contacts.js" },
    { "src": "/(.*)",          "dest": "/index.html"       }
  ]
}
